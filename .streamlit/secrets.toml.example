# ─────────────────────────────────────────────────────────────────────────────
# .streamlit/secrets.toml.example  —  SAFE TO COMMIT (no real keys)
#
#  Copy to .streamlit/secrets.toml and fill in your real credentials.
#  The actual secrets.toml is gitignored.
#
#  STREAMLIT CLOUD DEPLOYMENT:
#    Paste these exact key names into:
#    App Settings → Secrets
# ─────────────────────────────────────────────────────────────────────────────

AZURE_SPEECH_KEY    = "your-azure-speech-key-here"
AZURE_SPEECH_REGION = "eastus"
